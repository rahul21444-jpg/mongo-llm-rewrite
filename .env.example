# Copy to `.env` and fill in your values. `.env` is git-ignored — never commit secrets.

# LLM gateway (any Anthropic-compatible /v1/messages endpoint).
# NOTE: this client sends the key in the `api-key` header (Azure APIM style).
# If your provider uses Anthropic's native auth, change the header in llm_client.py to `x-api-key`.
LLM_API_KEY=your-key-here
LLM_BASE_URL=https://your-gateway/anthropic
LLM_MODEL=claude-sonnet-4-5

# Throwaway MongoDB used by the experiments (keep separate from any real instance).
MONGO_URI=mongodb://localhost:47017
